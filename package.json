{
  "name": "rocketcss",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "format-ci:prettier": "prettier --check .",
    "format-ci:toml": "taplo format --check",
    "format:prettier": "prettier --write .",
    "format:toml": "taplo format",
    "parser-test-corpus": "pnpm --filter @rocketcss/sync-upstream-css-tests generate-parser-corpus",
    "upstream-tests": "pnpm --filter @rocketcss/sync-upstream-css-tests upstream-tests"
  },
  "devDependencies": {
    "@taplo/cli": "^0.7.0",
    "prettier": "^3.6.2"
  }
}
