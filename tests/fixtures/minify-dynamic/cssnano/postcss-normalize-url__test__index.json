{
  "upstream": "packages/postcss-normalize-url/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should strip double quotes",
      "input": "h1{background:url(\"cat.jpg\")}",
      "expected": "h1{background:url(cat.jpg)}"
    },
    {
      "test": "should strip single quotes",
      "input": "h1{background:url('cat.jpg')}",
      "expected": "h1{background:url(cat.jpg)}"
    },
    {
      "test": "should strip double quotes uppercase URL",
      "input": "h1{background:URL(\"cat.jpg\")}",
      "expected": "h1{background:URL(cat.jpg)}"
    },
    {
      "test": "should escape special characters",
      "input": "h1{background:url(\"http://website.com/assets)_test.png\")}",
      "expected": "h1{background:url(http://website.com/assets\\)_test.png)}"
    },
    {
      "test": "should not escape more than one special character",
      "input": "h1{background:url(\"http://website.com/assets_(test).png\")}",
      "expected": "h1{background:url(\"http://website.com/assets_(test).png\")}",
      "passthrough": true
    },
    {
      "test": "should remove the default port",
      "input": "h1{background:url(http://website.com:80/image.png)}",
      "expected": "h1{background:url(http://website.com/image.png)}"
    },
    {
      "test": "should not remove the fragment",
      "input": "h1{background:url(test.svg#icon)}",
      "expected": "h1{background:url(test.svg#icon)}",
      "passthrough": true
    },
    {
      "test": "should not remove the fragment in absolute urls",
      "input": "h1{background:url(http://website.com/test.svg#icon)}",
      "expected": "h1{background:url(http://website.com/test.svg#icon)}",
      "passthrough": true
    },
    {
      "test": "should normalize directory traversal",
      "input": "h1{background:url(http://website.com/assets/css/../font/t.eot)}",
      "expected": "h1{background:url(http://website.com/assets/font/t.eot)}"
    },
    {
      "test": "should normalize directory traversal in relative urls",
      "input": "h1{background:url(css/../font/t.eot)}",
      "expected": "h1{background:url(font/t.eot)}"
    },
    {
      "test": "should trim current directory indicator in relative urls",
      "input": "h1{background:url(./images/cat.png)}",
      "expected": "h1{background:url(images/cat.png)}"
    },
    {
      "test": "should do the above tests, stripping quotes",
      "input": "h1{background:url(\"./css/../font/t.eot\")}",
      "expected": "h1{background:url(font/t.eot)}"
    },
    {
      "test": "should normalize urls with special characters",
      "input": "h1{background:url(\"http://website.com/test/../(images)/1.png\")}",
      "expected": "h1{background:url(\"http://website.com/(images)/1.png\")}"
    },
    {
      "test": "should normalize relative urls with special characters",
      "input": "h1{background:url(\"test/../(images)/1.png\")}",
      "expected": "h1{background:url(\"(images)/1.png\")}"
    },
    {
      "test": "should minimise whitespace inside the url function",
      "input": "h1{background:url(               test.png           )}",
      "expected": "h1{background:url(test.png)}"
    },
    {
      "test": "should minimise whitespace inside the url function (2)",
      "input": "h1{background:url(               )}",
      "expected": "h1{background:url()}"
    },
    {
      "test": "should minimise whitespace inside the url string",
      "input": "h1{background:url(\"               test.png      \")}",
      "expected": "h1{background:url(test.png)}"
    },
    {
      "test": "should minimise whitespace inside the url string (2)",
      "input": "h1{background:url(\"               \")}",
      "expected": "h1{background:url()}"
    },
    {
      "test": "should minimise whitespace with special characters",
      "input": "h1{background:url(\"           test (2015).png     \")}",
      "expected": "h1{background:url(\"test (2015).png\")}"
    },
    {
      "test": "should join multiline url functions",
      "input": "h1{background:url(\"some really long string \\\nspanning multiple lines\")}",
      "expected": "h1{background:url(\"some really long string spanning multiple lines\")}"
    },
    {
      "test": "should process multiple backgrounds",
      "input": "h1{background:url(   \"./test/../foo/bar.jpg\"  ), url(\"http://website.com/img.jpg\")}",
      "expected": "h1{background:url(foo/bar.jpg), url(http://website.com/img.jpg)}"
    },
    {
      "test": "should not mangle chrome extension urls",
      "input": "h1{background-image:url('chrome-extension://__MSG_@@extension_id__/someFile.png')}",
      "expected": "h1{background-image:url(chrome-extension://__MSG_@@extension_id__/someFile.png)}"
    },
    {
      "test": "should not mangle mozila extension urls",
      "input": "h1{background-image:url('moz-extension://__MSG_@@extension_id__/someFile.png')}",
      "expected": "h1{background-image:url(moz-extension://__MSG_@@extension_id__/someFile.png)}"
    },
    {
      "test": "should not mangle other extension urls",
      "input": "h1{background-image:url('other-other-extension://__MSG_@@extension_id__/someFile.png')}",
      "expected": "h1{background-image:url(other-other-extension://__MSG_@@extension_id__/someFile.png)}"
    },
    {
      "test": "should not mangle data urls",
      "input": ".has-svg:before{content:url(\"data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" viewBox=\"-0.5 0 20 15\"><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 4.0033 8.87436)\" height=\"5\" width=\"6.32304\" y=\"6.37436\" x=\"0.84178\"></rect><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 11.1776 7.7066)\" width=\"5\" height=\"16.79756\" y=\"-0.69218\" x=\"8.67764\"></rect></svg>\")}",
      "expected": ".has-svg:before{content:url(\"data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" viewBox=\"-0.5 0 20 15\"><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 4.0033 8.87436)\" height=\"5\" width=\"6.32304\" y=\"6.37436\" x=\"0.84178\"></rect><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 11.1776 7.7066)\" width=\"5\" height=\"16.79756\" y=\"-0.69218\" x=\"8.67764\"></rect></svg>\")}",
      "passthrough": true
    },
    {
      "test": "should not mangle data urls (2)",
      "input": ".has-svg:before{content:url(\"DATA:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" viewBox=\"-0.5 0 20 15\"><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 4.0033 8.87436)\" height=\"5\" width=\"6.32304\" y=\"6.37436\" x=\"0.84178\"></rect><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 11.1776 7.7066)\" width=\"5\" height=\"16.79756\" y=\"-0.69218\" x=\"8.67764\"></rect></svg>\")}",
      "expected": ".has-svg:before{content:url(\"DATA:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" viewBox=\"-0.5 0 20 15\"><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 4.0033 8.87436)\" height=\"5\" width=\"6.32304\" y=\"6.37436\" x=\"0.84178\"></rect><rect fill=\"white\" stroke=\"none\" transform=\"rotate(45 11.1776 7.7066)\" width=\"5\" height=\"16.79756\" y=\"-0.69218\" x=\"8.67764\"></rect></svg>\")}",
      "passthrough": true
    },
    {
      "test": "should not mangle empty data urls",
      "input": ".has-svg:before{content:url(data:,Hello%2C%20World!)}",
      "expected": ".has-svg:before{content:url(data:,Hello%2C%20World!)}",
      "passthrough": true
    },
    {
      "test": "should not mangle plain data urls",
      "input": ".has-svg:before{content:url(data:text/plain;base64,SGVsbG8sIFdvcmxkIQ%3D%3D)}",
      "expected": ".has-svg:before{content:url(data:text/plain;base64,SGVsbG8sIFdvcmxkIQ%3D%3D)}",
      "passthrough": true
    },
    {
      "test": "should not mangle text/html data urls",
      "input": ".has-svg:before{content:url(data:text/html,%3Ch1%3EHello%2C%20World!%3C%2Fh1%3E)}",
      "expected": ".has-svg:before{content:url(data:text/html,%3Ch1%3EHello%2C%20World!%3C%2Fh1%3E)}",
      "passthrough": true
    },
    {
      "test": "should not mangle text/html data urls (2)",
      "input": ".has-svg:before{content:url(\"data:text/html,%3Ch1%3EHello%2C%20World!%3C%2Fh1%3E\")}",
      "expected": ".has-svg:before{content:url(\"data:text/html,%3Ch1%3EHello%2C%20World!%3C%2Fh1%3E\")}",
      "passthrough": true
    },
    {
      "test": "should not mangle embedded fonts",
      "input": ".font:before{src:url(data:application/x-font-ttf;charset=utf-8;base64,) format('truetype')}",
      "expected": ".font:before{src:url(data:application/x-font-ttf;charset=utf-8;base64,) format('truetype')}",
      "passthrough": true
    },
    {
      "test": "should not mangle embedded fonts (2)",
      "input": ".font:before{src:url(data:font/truetype;charset=utf-8;base64,') format('truetype')}",
      "expected": ".font:before{src:url(data:font/truetype;charset=utf-8;base64,') format('truetype')}",
      "passthrough": true
    },
    {
      "test": "should optimise @namespace urls",
      "input": "@namespace islands url(\" http://bar.yandex.ru/ui/islands\");",
      "expected": "@namespace islands \"http://bar.yandex.ru/ui/islands\";"
    },
    {
      "test": "should optimise @namespace urls (2)",
      "input": "@namespace islands url(http://bar.yandex.ru/ui/islands );",
      "expected": "@namespace islands \"http://bar.yandex.ru/ui/islands\";"
    },
    {
      "test": "should optimise @namespace urls (3)",
      "input": "@namespace islands \" http://bar.yandex.ru/ui/islands \";",
      "expected": "@namespace islands \"http://bar.yandex.ru/ui/islands\";"
    },
    {
      "test": "should optimise @namespace urls (4)",
      "input": "@NAMESPACE islands \" http://bar.yandex.ru/ui/islands \";",
      "expected": "@NAMESPACE islands \"http://bar.yandex.ru/ui/islands\";"
    },
    {
      "test": "should not normalize @document urls",
      "input": "@document url(http://www.w3.org/),url-prefix(http://www.w3.org/Style/){body{font-size:2em}}",
      "expected": "@document url(http://www.w3.org/),url-prefix(http://www.w3.org/Style/){body{font-size:2em}}",
      "passthrough": true
    },
    {
      "test": "should handle protocol relative urls",
      "input": "h1{background:url(//website.com:80/image.png)}",
      "expected": "h1{background:url(//website.com/image.png)}"
    },
    {
      "test": "should preserve paths in parameters",
      "input": "background: url(https://ss0.example.com/70cFuh_Q1Yn/it/u=5088,2842&fm=26&gp=0.jpg?imageView2/1/w/750/h/1334)",
      "expected": "background: url(https://ss0.example.com/70cFuh_Q1Yn/it/u=5088,2842&fm=26&gp=0.jpg?imageView2/1/w/750/h/1334)",
      "passthrough": true
    },
    {
      "test": "should pass through when it doesn't find a url function",
      "input": "h1{color:black;font-weight:bold}",
      "expected": "h1{color:black;font-weight:bold}",
      "passthrough": true
    },
    {
      "test": "should pass through non-url empty functions",
      "input": "h1{shape-outside:circle()}",
      "expected": "h1{shape-outside:circle()}",
      "passthrough": true
    },
    {
      "test": "should pass through empty url",
      "input": "h1{background:url()}",
      "expected": "h1{background:url()}",
      "passthrough": true
    },
    {
      "test": "should pass through invalid url",
      "input": "h1{background:url(http://)}",
      "expected": "h1{background:url(http://)}",
      "passthrough": true
    }
  ]
}
