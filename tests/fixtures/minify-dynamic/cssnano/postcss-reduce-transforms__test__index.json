      "test": "should work with same env",
      "input": "h1{transform:scale(env(--foo), env(--foo))}",
      "expected": "h1{transform:scale(env(--foo))}"
    },
    {
      "test": "should pass through with variables and difference fallback values",
      "input": "h1{transform:scale(var(--foo, 1), var(--foo, 2))}",
      "expected": "h1{transform:scale(var(--foo, 1), var(--foo, 2))}",
      "passthrough": true
    },
    {
      "test": "should pass through with variables and difference fallback values #1",
      "input": "h1{transform:scale(var(--foo, calc(1 * 5)), var(--foo, calc(1 + 1)))}",
      "expected": "h1{transform:scale(var(--foo, calc(1 * 5)), var(--foo, calc(1 + 1)))}",
      "passthrough": true
    },
    {
      "test": "should pass through with variables and difference fallback values #2",
      "input": "h1{transform:scale(var(--foo, calc(1 * 1)), var(--foo, calc(1 + 1)))}",
      "expected": "h1{transform:scale(var(--foo, calc(1 * 1)), var(--foo, calc(1 + 1)))}",
      "passthrough": true
    },
    {
      "test": "should pass through invalid values",
      "input": "h1{transform:matrix3d(20, 20, 0, 0, 40, 40, 0, 0, 0, 0, 1, 0, 80, 80, 0, 1, 1)}",
      "expected": "h1{transform:matrix3d(20, 20, 0, 0, 40, 40, 0, 0, 0, 0, 1, 0, 80, 80, 0, 1, 1)}",
      "passthrough": true
    },
    {
      "test": "should pass through invalid values #1",
      "input": "h1{transform:rotate3d(1, 0, 0, 1, 1)}",
      "expected": "h1{transform:rotate3d(1, 0, 0, 1, 1)}",
      "passthrough": true
    },
    {
      "test": "should pass through invalid values #2",
      "input": "h1{transform:rotateZ(1, 1)}",
      "expected": "h1{transform:rotateZ(1, 1)}",
      "passthrough": true
    },
    {
      "test": "should pass through invalid values #3",
