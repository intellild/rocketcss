      "expected": "h1{transform:matrix3d(var(--a1), var(--b1), var(--c1), var(--d1), var(--a2), var(--b2), var(--c2), var(--d2), var(--a3), var(--b3), var(--c3), var(--d3), var(--a4), var(--b4), var(--c4), var(--d4))}",
      "passthrough": true
    },
    {
      "test": "should pass through variables #4",
      "input": "h1{transform:rotate3d(var(--foo))}",
      "expected": "h1{transform:rotate3d(var(--foo))}",
      "passthrough": true
    },
    {
      "test": "should pass through variables #5",
      "input": "h1{transform:rotate3d(var(--x), var(--y), var(--z), var(--a))}",
      "expected": "h1{transform:rotate3d(var(--x), var(--y), var(--z), var(--a))}",
      "passthrough": true
    },
    {
      "test": "should pass through variables #6",
      "input": "h1{transform:scale(var(--foo))}",
      "expected": "h1{transform:scale(var(--foo))}",
