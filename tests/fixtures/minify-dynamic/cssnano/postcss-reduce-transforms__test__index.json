    },
    {
      "test": "should work with variables #11",
      "input": "h1{transform:scale3d(1, 1, var(--foo))}",
      "expected": "h1{transform:scaleZ(var(--foo))}"
    },
    {
      "test": "should work with variables #12",
      "input": "h1{transform:translate(var(--foo), 0)}",
