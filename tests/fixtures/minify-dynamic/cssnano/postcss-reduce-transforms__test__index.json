      "passthrough": true
    },
    {
      "test": "should work with variables",
      "input": "h1{transform:matrix3d(var(--a), var(--b), 0, 0, var(--c), var(--d), 0, 0, 0, 0, 1, 0, var(--tx), var(--ty), 0, 1)}",
      "expected": "h1{transform:matrix(var(--a), var(--b), var(--c), var(--d), var(--tx), var(--ty))}"
    },
    {
      "test": "should work with variables #1",
      "input": "h1{transform:rotate3d(1, 0, 0, var(--foo))}",
      "expected": "h1{transform:rotateX(var(--foo))}"
    },
    {
      "test": "should work with variables #2",
      "input": "h1{transform:rotate3d(0, 1, 0, var(--foo))}",
