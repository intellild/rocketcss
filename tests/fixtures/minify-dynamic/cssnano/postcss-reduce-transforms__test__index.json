{
  "upstream": "packages/postcss-reduce-transforms/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should shorten matrix3d(a, b, 0, 0, c, d, 0, 0, 0, 0, 1, 0, tx, ty, 0, 1) to matrix(a, b, c, d, tx, ty)",
      "input": "h1{transform:matrix3d(20, 20, 0, 0, 40, 40, 0, 0, 0, 0, 1, 0, 80, 80, 0, 1)}",
      "expected": "h1{transform:matrix(20, 20, 40, 40, 80, 80)}"
    },
    {
      "test": "should shorten matrix3d(a, b, 0, 0, c, d, 0, 0, 0, 0, 1, 0, tx, ty, 0, 1) to matrix(a, b, c, d, tx, ty) (uppercase property)",
      "input": "h1{TRANSFORM:matrix3d(20, 20, 0, 0, 40, 40, 0, 0, 0, 0, 1, 0, 80, 80, 0, 1)}",
      "expected": "h1{TRANSFORM:matrix(20, 20, 40, 40, 80, 80)}"
    },
    {
      "test": "should shorten matrix3d(a, b, 0, 0, c, d, 0, 0, 0, 0, 1, 0, tx, ty, 0, 1) to matrix(a, b, c, d, tx, ty) (uppercase value)",
      "input": "h1{TRANSFORM:MATRIX3D(20, 20, 0, 0, 40, 40, 0, 0, 0, 0, 1, 0, 80, 80, 0, 1)}",
      "expected": "h1{TRANSFORM:matrix(20, 20, 40, 40, 80, 80)}"
    },
    {
      "test": "should pass through other 3d matrices",
      "input": "h1{transform:matrix3d(.8535533905932737,.4999999999999999,.14644660940672619,0,-.4999999999999999,.7071067811865476,.4999999999999999,0,.14644660940672619,-.4999999999999999,.8535533905932737,0,22.62994231491119,-20.3223304703363,101.3700576850888,1)}",
      "expected": "h1{transform:matrix3d(.8535533905932737,.4999999999999999,.14644660940672619,0,-.4999999999999999,.7071067811865476,.4999999999999999,0,.14644660940672619,-.4999999999999999,.8535533905932737,0,22.62994231491119,-20.3223304703363,101.3700576850888,1)}",
      "passthrough": true
    },
    {
      "test": "should shorten rotateZ to rotate",
      "input": "h1{transform:rotateZ(180deg)}",
      "expected": "h1{transform:rotate(180deg)}"
    },
    {
      "test": "should shorten rotateZ to rotate (uppercase value)",
      "input": "h1{transform:ROTATEZ(180deg)}",
      "expected": "h1{transform:rotate(180deg)}"
    },
    {
      "test": "should shorten rotate3d(1, 0, 0, a) to rotateX(a)",
      "input": "h1{transform:rotate3d(1, 0, 0, 20deg)}",
      "expected": "h1{transform:rotateX(20deg)}"
    },
    {
      "test": "should shorten rotate3d(1, 0, 0, a) to rotateX(a) (uppercase value)",
      "input": "h1{transform:ROTATE3D(1, 0, 0, 20deg)}",
      "expected": "h1{transform:rotateX(20deg)}"
    },
    {
      "test": "should shorten rotate3d(0, 1, 0, a) to rotateY(a)",
      "input": "h1{transform:rotate3d(0, 1, 0, 20deg)}",
      "expected": "h1{transform:rotateY(20deg)}"
    },
    {
      "test": "should shorten rotate3d(0, 0, 1, a) to rotate(a)",
      "input": "h1{transform:rotate3d(0, 0, 1, 20deg)}",
      "expected": "h1{transform:rotate(20deg)}"
    },
    {
      "test": "should pass through other rotate3d arguments",
      "input": "h1{transform:rotate3d(1.5, 1.5, 0, 45deg)}",
      "expected": "h1{transform:rotate3d(1.5, 1.5, 0, 45deg)}",
      "passthrough": true
    },
    {
      "test": "should shorten scale(0, 0) to scale(0)",
      "input": "h1{transform:scale(0, 0)}",
      "expected": "h1{transform:scale(0)}"
    },
    {
      "test": "should shorten scale(sx, sy) to scale(sx)",
      "input": "h1{transform:scale(1.5, 1.5)}",
      "expected": "h1{transform:scale(1.5)}"
    },
    {
      "test": "should shorten scale(sx, 1) to scaleX(sx)",
      "input": "h1{transform:scale(1.5, 1)}",
      "expected": "h1{transform:scaleX(1.5)}"
    },
    {
      "test": "should shorten scale(1, sy) to scaleY(sy)",
      "input": "h1{transform:scale(1, 1.5)}",
      "expected": "h1{transform:scaleY(1.5)}"
    },
    {
      "test": "should pass through 1 argument scale",
      "input": "h1{transform:scale(1.5)}",
      "expected": "h1{transform:scale(1.5)}",
      "passthrough": true
    },
    {
      "test": "should pass through 2 different arguments scale",
      "input": "h1{transform:scale(1.5,3)}",
      "expected": "h1{transform:scale(1.5,3)}",
      "passthrough": true
    },
    {
      "test": "should shorten scale3d(sx, 1, 1) to scaleX(sx)",
      "input": "h1{transform:scale3d(1.5, 1, 1)}",
      "expected": "h1{transform:scaleX(1.5)}"
    },
    {
      "test": "should shorten scale3d(1, sy, 1) to scaleY(sy)",
      "input": "h1{transform:scale3d(1, 1.5, 1)}",
      "expected": "h1{transform:scaleY(1.5)}"
    },
    {
      "test": "should shorten scale3d(1, 1, sz) to scaleZ(sz)",
      "input": "h1{transform:scale3d(1, 1, 1.5)}",
      "expected": "h1{transform:scaleZ(1.5)}"
    },
    {
      "test": "should pass through other scale3d arguments",
      "input": "h1{transform:scale3d(1.5, 1.5, 3)}",
      "expected": "h1{transform:scale3d(1.5, 1.5, 3)}",
      "passthrough": true
    },
    {
      "test": "should pass through translate with 1 argument",
      "input": "h1{transform:translate(5)}",
      "expected": "h1{transform:translate(5)}",
      "passthrough": true
    },
    {
      "test": "should not shorten translate(tx, ty) to translate(tx)",
      "input": "h1{transform:translate(5, 5)}",
      "expected": "h1{transform:translate(5, 5)}"
    },
    {
      "test": "should shorten translate(tx, 0) to translate(tx)",
      "input": "h1{transform:translate(5, 0)}",
      "expected": "h1{transform:translate(5)}"
    },
    {
      "test": "should shorten translate(0, ty) to translateY(ty)",
      "input": "h1{transform:translate(0, 5)}",
      "expected": "h1{transform:translateY(5)}"
    },
    {
      "test": "should shorten translate3d(0, 0, tz) to translateZ(tz)",
      "input": "h1{transform:translate3d(0, 0, 2)}",
      "expected": "h1{transform:translateZ(2)}"
    },
    {
      "test": "should pass through other translate3d arguments",
      "input": "h1{transform:translate3d(1.5,1.5,3)}",
      "expected": "h1{transform:translate3d(1.5,1.5,3)}",
      "passthrough": true
    },
    {
      "test": "should work with vendor prefixes",
      "input": "h1{-webkit-transform:translate3d(0, 0, 0)}",
      "expected": "h1{-webkit-transform:translateZ(0)}"
    },
    {
      "test": "should work with vendor prefixes #1",
      "input": "h1{-moz-transform:translate3d(0, 0, 0)}",
      "expected": "h1{-moz-transform:translateZ(0)}"
    },
    {
      "test": "should work with vendor prefixes (uppercase property)",
      "input": "h1{-WEBKIT-TRANSFORM:translate3d(0, 0, 0)}",
      "expected": "h1{-WEBKIT-TRANSFORM:translateZ(0)}"
    },
    {
      "test": "should work with vendor prefixes (uppercase value)",
      "input": "h1{-WEBKIT-TRANSFORM:TRANSLATE3D(0, 0, 0)}",
      "expected": "h1{-WEBKIT-TRANSFORM:translateZ(0)}"
    },
    {
      "test": "should pass through variables",
      "input": "h1{transform:var(--foo)}",
      "expected": "h1{transform:var(--foo)}",
      "passthrough": true
    },
    {
      "test": "should pass through variables #1",
      "input": "h1{transform:matrix3d(var(--foo))}",
      "expected": "h1{transform:matrix3d(var(--foo))}",
      "passthrough": true
    },
    {
      "test": "should pass through variables #2",
      "input": "h1{transform:matrix3d(var(--a1), var(--a2), var(--a3), var(--a4))}",
      "expected": "h1{transform:matrix3d(var(--a1), var(--a2), var(--a3), var(--a4))}",
      "passthrough": true
    },
    {
      "test": "should pass through variables #3",
