{
  "upstream": "packages/postcss-merge-longhand/test/columns.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should merge column values",
      "input": "h1{column-width:12em;column-count:auto}",
      "expected": "h1{columns:12em}"
    },
    {
      "test": "should merge column values (uppercase)",
      "input": "h1{COLUMN-WIDTH:12em;COLUMN-COUNT:auto}",
      "expected": "h1{columns:12em}"
    },
    {
      "test": "should minify column values",
      "input": "h1{column-width:auto;column-count:auto}",
      "expected": "h1{columns:auto}"
    },
    {
      "test": "should minify column values (uppercase)",
      "input": "h1{COLUMN-WIDTH:auto;COLUMN-COUNT:auto}",
      "expected": "h1{columns:auto}"
    },
    {
      "test": "should minify column values 1 (uppercase)",
      "input": "h1{column-width:AUTO;column-count:AUTO}",
      "expected": "h1{columns:AUTO}"
    },
    {
      "test": "should merge column-width with columns",
      "input": "h1{columns:12em auto;column-width:11em}",
      "expected": "h1{columns:11em}"
    },
    {
      "test": "should merge column-width with columns (uppercase)",
      "input": "h1{COLUMNS:12em auto;COLUMN-WIDTH:11em}",
      "expected": "h1{columns:11em}"
    },
    {
      "test": "should merge column-width with columns (uppercase) #1",
      "input": "h1{columns:12em AUTO;column-width:11em}",
      "expected": "h1{columns:11em}"
    },
    {
      "test": "should merge column width and column count",
      "input": "h1{column-width:6em;column-count:3}",
      "expected": "h1{columns:6em 3}"
    },
    {
      "test": "should merge column width and column count (uppercase)",
      "input": "h1{COLUMN-WIDTH:6em;COLUMN-COUNT:3}",
      "expected": "h1{columns:6em 3}"
    },
    {
      "test": "should pass through column width",
      "input": "h1{column-width:6em}",
      "expected": "h1{column-width:6em}",
      "passthrough": true
    },
    {
      "test": "should pass through column width (uppercase)",
      "input": "h1{COLUMN-WIDTH:6em}",
      "expected": "h1{COLUMN-WIDTH:6em}",
      "passthrough": true
    },
    {
      "test": "should pass through column count",
      "input": "h1{column-count:3}",
      "expected": "h1{column-count:3}",
      "passthrough": true
    },
    {
      "test": "should pass through column count (uppercase)",
      "input": "h1{COLUMN-COUNT:3}",
      "expected": "h1{COLUMN-COUNT:3}",
      "passthrough": true
    },
    {
      "test": "should reduce inherit",
      "input": "h1{column-width:inherit;column-count:inherit}",
      "expected": "h1{columns:inherit}"
    },
    {
      "test": "should reduce inherit (uppercase)",
      "input": "h1{COLUMN-WIDTH:inherit;COLUMN-COUNT:inherit}",
      "expected": "h1{columns:inherit}"
    },
    {
      "test": "should reduce inherit 1 (uppercase)",
      "input": "h1{COLUMN-WIDTH:INHERIT;COLUMN-COUNT:INHERIT}",
      "expected": "h1{columns:inherit}"
    },
    {
      "test": "should pass through auto",
      "input": "h1{columns:auto}",
      "expected": "h1{columns:auto}",
      "passthrough": true
    },
    {
      "test": "should pass through auto (uppercase)",
      "input": "h1{COLUMNS:auto}",
      "expected": "h1{columns:auto}"
    },
    {
      "test": "should pass through auto 1 (uppercase)",
      "input": "h1{columns:AUTO}",
      "expected": "h1{columns:auto}"
    },
    {
      "test": "should not merge declarations with hacks",
      "input": "h1{column-width:12em;_column-count:auto}",
      "expected": "h1{column-width:12em;_column-count:auto}",
      "passthrough": true
    },
    {
      "test": "should not merge declarations with hacks (uppercase)",
      "input": "h1{COLUMN-WIDTH:12em;_COLUMN-COUNT:auto}",
      "expected": "h1{COLUMN-WIDTH:12em;_COLUMN-COUNT:auto}",
      "passthrough": true
    },
    {
      "test": "should preserve nesting level",
      "input": "section{h1{column-width:12em;column-count:auto}}",
      "expected": "section{h1{columns:12em}}"
    },
    {
      "test": "should preserve nesting level (uppercase)",
      "input": "section{h1{COLUMN-WIDTH:12em;COLUMN-COUNT:auto}}",
      "expected": "section{h1{columns:12em}}"
    },
    {
      "test": "should save fallbacks for column-width if after goes custom css props",
      "input": "h1{column-width:12em;column-width:var(--variable)}",
      "expected": "h1{column-width:12em;column-width:var(--variable)}"
    },
    {
      "test": "should save fallbacks for column-width if after goes custom css props (uppercase)",
      "input": "h1{COLUMN-WIDTH:12em;COLUMN-WIDTH:var(--variable)}",
      "expected": "h1{COLUMN-WIDTH:12em;COLUMN-WIDTH:var(--variable)}"
    },
    {
      "test": "should save fallbacks for column-width if after goes custom css props 1 (uppercase)",
      "input": "h1{column-width:12em;column-width:VAR(--variable)}",
      "expected": "h1{column-width:12em;column-width:VAR(--variable)}"
    },
    {
      "test": "should not explode columns with custom properties",
      "input": "h1{columns:var(--variable)}",
      "expected": "h1{columns:var(--variable)}",
      "passthrough": true
    },
    {
      "test": "should preserve case of custom properties",
      "input": "h1{columns:var(--fooBar)}",
      "expected": "h1{columns:var(--fooBar)}",
      "passthrough": true
    },
    {
      "test": "should preserve case of custom properties (uppercase)",
      "input": "h1{COLUMN:var(--fooBar)}",
      "expected": "h1{COLUMN:var(--fooBar)}",
      "passthrough": true
    },
    {
      "test": "should preserve case of custom properties 1 (uppercase)",
      "input": "h1{column:VAR(--fooBar)}",
      "expected": "h1{column:VAR(--fooBar)}",
      "passthrough": true
    },
    {
      "test": "should merge column values duplicate columns",
      "input": "h1{column-width:12em;column-count:auto;columns:12em}",
      "expected": "h1{columns:12em}"
    },
    {
      "test": "should merge column values duplicate columns (uppercase)",
      "input": "h1{COLUMN-WIDTH:12em;COLUMN-COUNT:auto;COLUMNS:12em}",
      "expected": "h1{columns:12em}"
    },
    {
      "test": "should handle empty columns",
      "input": "h1{columns:;}",
      "expected": "h1{columns:;}"
    }
  ]
}
