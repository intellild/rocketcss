      "expected": "h1{padding:INHERIT}"
    },
    {
      "test": "should not merge margin props when one has a revert property",
      "input": "h1{margin:10px;margin-left:revert}",
      "expected": "h1{margin:10px;margin-left:revert}"
    },
    {
      "test": "should not merge MARGIN props when one has a revert property",
      "input": "h1{MARGIN:10px;MARGIN-left:revert}",
      "expected": "h1{margin:10px;MARGIN-left:revert}"
    },
    {
      "test": "should not merge padding props when one has a revert property",
      "input": "h1{padding:10px;padding-left:revert}",
      "expected": "h1{padding:10px;padding-left:revert}"
    },
    {
      "test": "should not merge PADDING props when one has a revert property",
      "input": "h1{PADDING:10px;PADDING-left:revert}",
      "expected": "h1{padding:10px;PADDING-left:revert}"
    },
    {
      "test": "should handle empty margin properties",
      "input": "h1{margin:;}",
      "expected": "h1{margin:;}"
    },
    {
      "test": "should handle empty MARGIN properties",
      "input": "h1{MARGIN:;}",
      "expected": "h1{MARGIN:;}"
    },
    {
      "test": "should handle empty padding properties",
      "input": "h1{padding:;}",
      "expected": "h1{padding:;}"
    },
    {
      "test": "should handle empty PADDING properties",
      "input": "h1{PADDING:;}",
      "expected": "h1{PADDING:;}"
    }
  ]
}
