    {
      "test": "should convert a unicode range to a wildcard range",
      "input": "@font-face{font-family:test;unicode-range:u+2b00-2bff}*{font-family:test}",
      "expected": "@font-face{font-family:test;unicode-range:u+2b??}*{font-family:test}"
    },
    {
      "test": "should convert a unicode range to a wildcard range (2)",
      "input": "@font-face{font-family:test;unicode-range:u+1e00-1eff}*{font-family:test}",
      "expected": "@font-face{font-family:test;unicode-range:u+1e??}*{font-family:test}"
    },
    {
      "test": "should convert a unicode range to a wildcard range (3)",
