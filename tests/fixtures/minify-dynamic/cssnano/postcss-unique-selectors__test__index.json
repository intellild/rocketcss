{
  "upstream": "packages/postcss-unique-selectors/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should deduplicate selectors",
      "input": "h1,h1,h1,h1{color:red}",
      "expected": "h1{color:red}"
    },
    {
      "test": "should sort selectors",
      "input": "h1,h10,H2,h7{color:red}",
      "expected": "H2,h1,h10,h7{color:red}"
    },
    {
      "test": "should keep comments in the selector",
      "input": ".newbackbtn,/*.searchall,*/.calNav{padding:5px;}",
      "expected": "/*.searchall,*/.calNav,.newbackbtn{padding:5px;}"
    },
    {
      "test": "should keep comments in the selector (2)",
      "input": ".x/*a*/,/*b*/.y/*c*/,.x,.y{padding:5px;}",
      "expected": ".x/*a*/,/*b*/.y/*c*/{padding:5px;}"
    },
    {
      "test": "should keep comments in the selector (3)",
      "input": ".x,.y,/*a*/.x/*b*/,/*c*/.y/*d*/{padding:5px;}",
      "expected": ".x/*a*//*b*/,.y/*c*//*d*/{padding:5px;}"
    },
    {
      "test": "should keep comments in the selector (4)",
      "input": ":is(/*a*/.x/*b*/,/*c*/.y/*d*/), :is(.x,.y),{padding:5px;}",
      "expected": ":is(/*a*/.x/*b*/,/*c*/.y/*d*/){padding:5px;}"
    }
  ]
}
