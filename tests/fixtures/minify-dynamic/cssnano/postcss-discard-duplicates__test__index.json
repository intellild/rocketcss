{
  "upstream": "packages/postcss-discard-duplicates/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should remove duplicate rules",
      "input": "h1{font-weight:bold}h1{font-weight:bold}",
      "expected": "h1{font-weight:bold}"
    },
    {
      "test": "should remove duplicate rules (2)",
      "input": "h1{color:#000}h2{color:#fff}h1{color:#000}",
      "expected": "h2{color:#fff}h1{color:#000}"
    },
    {
      "test": "should remove duplicate rules (3)",
      "input": "h1 { font-weight: bold }\nh1{font-weight:bold}",
      "expected": "h1{font-weight:bold}"
    },
    {
      "test": "should remove duplicate declarations",
      "input": "h1{font-weight:bold;font-weight:bold}",
      "expected": "h1{font-weight:bold}"
    },
    {
      "test": "should remove duplicate declarations, with comments",
      "input": "h1{/*test*/font-weight:bold}h1{/*test*/font-weight:bold}",
      "expected": "h1{/*test*/font-weight:bold}"
    },
    {
      "test": "should remove duplicate @rules",
      "input": "@charset \"utf-8\";@charset \"utf-8\";",
      "expected": "@charset \"utf-8\";"
    },
    {
      "test": "should remove duplicate @rules (2)",
      "input": "@charset \"utf-8\";@charset \"hello!\";@charset \"utf-8\";",
      "expected": "@charset \"hello!\";@charset \"utf-8\";"
    },
    {
      "test": "should remove duplicates inside @media queries",
      "input": "@media print{h1{display:block}h1{display:block}}",
      "expected": "@media print{h1{display:block}}"
    },
    {
      "test": "should remove duplicate @media queries",
      "input": "@media print{h1{display:block}}@media print{h1{display:block}}",
      "expected": "@media print{h1{display:block}}"
    },
    {
      "test": "should not mangle same keyframe rules but with different vendors",
      "input": "@-webkit-keyframes flash{0%,50%,100%{opacity:1}25%,75%{opacity:0}}@keyframes flash{0%,50%,100%{opacity:1}25%,75%{opacity:0}}",
      "expected": "@-webkit-keyframes flash{0%,50%,100%{opacity:1}25%,75%{opacity:0}}@keyframes flash{0%,50%,100%{opacity:1}25%,75%{opacity:0}}",
      "passthrough": true
    },
    {
      "test": "should not merge across keyframes",
      "input": "@-webkit-keyframes test{0%{color:#000}to{color:#fff}}@keyframes test{0%{color:#000}to{color:#fff}}",
      "expected": "@-webkit-keyframes test{0%{color:#000}to{color:#fff}}@keyframes test{0%{color:#000}to{color:#fff}}",
      "passthrough": true
    },
    {
      "test": "should not merge across keyframes (2)",
      "input": "@-webkit-keyframes slideInDown{0%{-webkit-transform:translateY(-100%);transform:translateY(-100%);visibility:visible}to{-webkit-transform:translateY(0);transform:translateY(0)}}@keyframes slideInDown{0%{-webkit-transform:translateY(-100%);transform:translateY(-100%);visibility:visible}to{-webkit-transform:translateY(0);transform:translateY(0)}}",
      "expected": "@-webkit-keyframes slideInDown{0%{-webkit-transform:translateY(-100%);transform:translateY(-100%);visibility:visible}to{-webkit-transform:translateY(0);transform:translateY(0)}}@keyframes slideInDown{0%{-webkit-transform:translateY(-100%);transform:translateY(-100%);visibility:visible}to{-webkit-transform:translateY(0);transform:translateY(0)}}",
      "passthrough": true
    },
    {
      "test": "should remove declarations before rules",
      "input": "h1{font-weight:bold;font-weight:bold}h1{font-weight:bold}",
      "expected": "h1{font-weight:bold}"
    },
    {
      "test": "should not deduplicate comments",
      "input": "h1{color:#000}/*test*/h2{color:#fff}/*test*/",
      "expected": "h1{color:#000}/*test*/h2{color:#fff}/*test*/",
      "passthrough": true
    },
    {
      "test": "should not crash on @layer syntax",
      "input": "@layer ui-components { } @layer ui-components",
      "expected": "@layer ui-components { } @layer ui-components"
    },
    {
      "test": "should not remove declarations when selectors are different",
      "input": "h1{font-weight:bold}h2{font-weight:bold}",
      "expected": "h1{font-weight:bold}h2{font-weight:bold}",
      "passthrough": true
    },
    {
      "test": "should not remove across contexts",
      "input": "h1{display:block}@media print{h1{display:block}}",
      "expected": "h1{display:block}@media print{h1{display:block}}",
      "passthrough": true
    },
    {
      "test": "should not be responsible for normalising selectors",
      "input": "h1,h2{font-weight:bold}h2,h1{font-weight:bold}",
      "expected": "h1,h2{font-weight:bold}h2,h1{font-weight:bold}",
      "passthrough": true
    },
    {
      "test": "should not be responsible for normalising declarations",
      "input": "h1{margin:10px 0 10px 0;margin:10px 0}",
      "expected": "h1{margin:10px 0 10px 0;margin:10px 0}",
      "passthrough": true
    },
    {
      "test": "should remove duplicate rules and declarations",
      "input": "h1{color:#000}h2{color:#fff}h1{color:#000;color:#000}",
      "expected": "h2{color:#fff}h1{color:#000}"
    },
    {
      "test": "should remove differently ordered duplicates",
      "input": "h1{color:black;font-size:12px}h1{font-size:12px;color:black}",
      "expected": "h1{font-size:12px;color:black}"
    },
    {
      "test": "should remove partial duplicates",
      "input": "h1{color:red;background:blue}h1{color:red}",
      "expected": "h1{background:blue}h1{color:red}"
    },
    {
      "test": "should preserve browser hacks (1)",
      "input": "h1{_color:white;color:white}",
      "expected": "h1{_color:white;color:white}",
      "passthrough": true
    },
    {
      "test": "should preserve browser hacks (2)",
      "input": "@media \u0000 all {}@media all {}",
      "expected": "@media \u0000 all {}@media all {}",
      "passthrough": true
    }
  ]
}
