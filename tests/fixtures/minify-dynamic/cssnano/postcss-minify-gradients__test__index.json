{
  "upstream": "packages/postcss-minify-gradients/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "linear: should convert \"to top\" to 0deg",
      "input": "background:linear-gradient(to top,#ffe500,#121)",
      "expected": "background:linear-gradient(0deg,#ffe500,#121)"
    },
    {
      "test": "linear: should convert \"to top\" to 0deg (uppercase property and value)",
      "input": "BACKGROUND:LINEAR-GRADIENT(TO TOP,#ffe500,#121)",
      "expected": "BACKGROUND:LINEAR-GRADIENT(0deg,#ffe500,#121)"
    },
    {
      "test": "linear: should convert \"to right\" to 90deg",
      "input": "background:linear-gradient(to right,#ffe500,#121)",
      "expected": "background:linear-gradient(90deg,#ffe500,#121)"
    },
    {
      "test": "linear: should convert \"to right\" to 90deg (uppercase property and value)",
      "input": "BACKGROUND:LINEAR-GRADIENT(TO RIGHT,#FFE500,#121)",
      "expected": "BACKGROUND:LINEAR-GRADIENT(90deg,#FFE500,#121)"
    },
    {
      "test": "linear: should convert \"to bottom\" to 180deg",
      "input": "background:linear-gradient(to bottom,#ffe500,#121)",
      "expected": "background:linear-gradient(180deg,#ffe500,#121)"
    },
    {
      "test": "linear: should convert \"to left\" to 270deg",
      "input": "background:linear-gradient(to left,#ffe500,#121)",
      "expected": "background:linear-gradient(270deg,#ffe500,#121)"
    },
    {
      "test": "linear: should convert \"to top\" to 0deg (with a solid colour)",
      "input": "background:#ffe500 linear-gradient(to top,#ffe500,#121)",
      "expected": "background:#ffe500 linear-gradient(0deg,#ffe500,#121)"
    },
    {
      "test": "repeating-linear: should convert \"to top\" to 0deg",
      "input": "background:repeating-linear-gradient(to top,#ffe500,#121)",
      "expected": "background:repeating-linear-gradient(0deg,#ffe500,#121)"
    },
    {
      "test": "repeating-linear: should convert \"to top\" to 0deg (uppercase)",
      "input": "background:REPEATING-LINEAR-GRADIENT(TO TOP,#ffe500,#121)",
      "expected": "background:REPEATING-LINEAR-GRADIENT(0deg,#ffe500,#121)"
    },
    {
      "test": "repeating-linear: should convert \"to right\" to 90deg",
      "input": "background:repeating-linear-gradient(to right,#ffe500,#121)",
      "expected": "background:repeating-linear-gradient(90deg,#ffe500,#121)"
    },
    {
      "test": "repeating-linear: should convert \"to bottom\" to 180deg",
      "input": "background:repeating-linear-gradient(to bottom,#ffe500,#121)",
      "expected": "background:repeating-linear-gradient(180deg,#ffe500,#121)"
    },
    {
      "test": "repeating-linear: should convert \"to left\" to 270deg",
      "input": "background:repeating-linear-gradient(to left,#ffe500,#121)",
      "expected": "background:repeating-linear-gradient(270deg,#ffe500,#121)"
    },
    {
      "test": "repeating-linear: should not remove necessary zero start length",
      "input": "background:repeating-linear-gradient(-45deg,transparent 0 25%,#d1d3d5 25% 50%)",
      "expected": "background:repeating-linear-gradient(-45deg,transparent 0 25%,#d1d3d5 25% 50%)",
      "passthrough": true
    },
    {
      "test": "linear: should not convert \"to top right\" to an angle",
      "input": "background:linear-gradient(to top right,#ffe500,#121)",
      "expected": "background:linear-gradient(to top right,#ffe500,#121)",
      "passthrough": true
    },
    {
      "test": "linear: should not convert \"to bottom left\" to an angle",
      "input": "background:linear-gradient(to bottom left,#ffe500,#121)",
      "expected": "background:linear-gradient(to bottom left,#ffe500,#121)",
      "passthrough": true
    },
    {
      "test": "linear: should reduce length values if they are the same",
      "input": "background:linear-gradient(45deg,#ffe500 50%,#121 50%)",
      "expected": "background:linear-gradient(45deg,#ffe500 50%,#121 0)"
    },
    {
      "test": "linear: should reduce length values if they are the same (uppercase)",
      "input": "background:LINEAR-GRADIENT(45DEG,#FFE500 50%,#121 50%)",
      "expected": "background:LINEAR-GRADIENT(45DEG,#FFE500 50%,#121 0)"
    },
    {
      "test": "linear: should reduce length values if they are less",
      "input": "background:linear-gradient(45deg,#ffe500 50%,#121 25%)",
      "expected": "background:linear-gradient(45deg,#ffe500 50%,#121 0)"
    },
    {
      "test": "linear: should not reduce length values with different units",
      "input": "background:linear-gradient(45deg,#ffe500 25px,#121 20%)",
      "expected": "background:linear-gradient(45deg,#ffe500 25px,#121 20%)",
      "passthrough": true
    },
    {
      "test": "linear: should remove the (unnecessary) start/end length values",
      "input": "background:linear-gradient(#ffe500 0%,#121 100%)",
      "expected": "background:linear-gradient(#ffe500,#121)"
    },
    {
      "test": "repeating-radial: should reduce length values if they are the same",
      "input": "background:repeating-radial-gradient(#121,#121 5px,#ffe500 5px,#ffe500 10px)",
      "expected": "background:repeating-radial-gradient(#121,#121 5px,#ffe500 0,#ffe500 10px)"
    },
    {
      "test": "repeating-radial: should reduce length values if they are the same (uppercase property and value)",
      "input": "BACKGROUND:REPEATING-RADIAL-GRADIENT(#121,#121 5PX,#FFE500 5PX,#FFE500 10PX)",
      "expected": "BACKGROUND:REPEATING-RADIAL-GRADIENT(#121,#121 5PX,#FFE500 0,#FFE500 10PX)"
    },
    {
      "test": "repeating-radial: should reduce length values if they are the same (last is zero)",
      "input": "BACKGROUND:REPEATING-RADIAL-GRADIENT(#121,#121 5PX,#FFE500 5PX,#FFE500 0)",
      "expected": "BACKGROUND:REPEATING-RADIAL-GRADIENT(#121,#121 5PX,#FFE500 0,#FFE500 0)"
    },
    {
      "test": "radial: should correctly account for \"at\"",
      "input": "background:radial-gradient(at 50% 0%,rgba(74,74,74,.15),transparent 40%);",
      "expected": "background:radial-gradient(at 50% 0%,rgba(74,74,74,.15),transparent 40%);",
      "passthrough": true
    },
    {
      "test": "radial: should correctly account for uppercase \"at\"",
      "input": "background:radial-gradient(AT 50% 0%,rgba(74,74,74,.15),transparent 40%);",
      "expected": "background:radial-gradient(AT 50% 0%,rgba(74,74,74,.15),transparent 40%);",
      "passthrough": true
    },
    {
      "test": "radial: should correctly account for \"at\" (2)",
      "input": "background:radial-gradient(at 50% 0%,rgba(74,74,74,.15),transparent 40%, red 40%);",
      "expected": "background:radial-gradient(at 50% 0%,rgba(74,74,74,.15),transparent 40%, red 0);"
    },
    {
      "test": "radial: should correctly account for \"at\" (2) (uppercase)",
      "input": "background:radial-gradient(AT 50% 0%,RGBA(74,74,74,.15),TRANSPARENT 40%, RED 40%);",
      "expected": "background:radial-gradient(AT 50% 0%,RGBA(74,74,74,.15),TRANSPARENT 40%, RED 0);"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (1)",
      "input": "background: -webkit-radial-gradient(50% 26%, circle, #fff, rgba(255, 255, 255, 0) 24%)",
      "expected": "background: -webkit-radial-gradient(50% 26%, circle, #fff, rgba(255, 255, 255, 0) 24%)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (1) (uppercase)",
      "input": "background: -WEBKIT-RADIAL-GRADIENT(50% 26%, circle, #fff, rgba(255, 255, 255, 0) 24%)",
      "expected": "background: -WEBKIT-RADIAL-GRADIENT(50% 26%, circle, #fff, rgba(255, 255, 255, 0) 24%)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (1) with px",
      "input": "background: -webkit-radial-gradient(50% 26px, circle, #fff, rgba(255, 255, 255, 0) 24%)",
      "expected": "background: -webkit-radial-gradient(50% 26px, circle, #fff, rgba(255, 255, 255, 0) 24%)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (1) with px (uppercase)",
      "input": "background: -webkit-radial-gradient(50% 26PX, circle, #fff, rgba(255, 255, 255, 0) 24%)",
      "expected": "background: -webkit-radial-gradient(50% 26PX, circle, #fff, rgba(255, 255, 255, 0) 24%)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (2)",
      "input": "background: -webkit-radial-gradient(center, 30% 30%, white 20%, black 10%)",
      "expected": "background: -webkit-radial-gradient(center, 30% 30%, white 20%, black 0)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (2) (uppercase)",
      "input": "background: -WEBKIT-RADIAL-GRADIENT(CENTER, 30% 30%, WHITE 20%, BLACK 10%)",
      "expected": "background: -WEBKIT-RADIAL-GRADIENT(CENTER, 30% 30%, WHITE 20%, BLACK 0)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (3)",
      "input": "background: -webkit-radial-gradient(50% 26%, #fff, rgba(255, 255, 255, 0) 24%)",
      "expected": "background: -webkit-radial-gradient(50% 26%, #fff, rgba(255, 255, 255, 0) 24%)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (4)",
      "input": "background: -webkit-radial-gradient(white 50%, black 40%)",
      "expected": "background: -webkit-radial-gradient(white 50%, black 0)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (4) (uppercase)",
      "input": "background: -WEBKIT-RADIAL-GRADIENT(WHITE 50%, BLACK 40%)",
      "expected": "background: -WEBKIT-RADIAL-GRADIENT(WHITE 50%, BLACK 0)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (4) with px (uppercase)",
      "input": "background: -WEBKIT-RADIAL-GRADIENT(WHITE 50px, BLACK 400PX)",
      "expected": "background: -WEBKIT-RADIAL-GRADIENT(WHITE 50px, BLACK 400PX)"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (5)",
      "input": "background: -webkit-radial-gradient(white calc(30%), black calc(50%))",
      "expected": "background: -webkit-radial-gradient(white calc(30%), black calc(50%))"
    },
    {
      "test": "radial: should correctly account with prefix \"-webkit\" (5) (calc uppercase)",
      "input": "background: -webkit-radial-gradient(white CALC(30%), black calc(50%))",
      "expected": "background: -webkit-radial-gradient(white CALC(30%), black calc(50%))"
    },
    {
      "test": "should not mangle floating point numbers",
      "input": "background:linear-gradient(#fff,#fff 2em,#ccc 2em,#ccc 2.1em,#fff 2.1em)",
      "expected": "background:linear-gradient(#fff,#fff 2em,#ccc 0,#ccc 2.1em,#fff 0)"
    },
    {
      "test": "should not mangle floating point numbers (uppercase)",
      "input": "background:LINEAR-GRADIENT(#FFF,#FFF 2EM,#CCC 2EM,#CCC 2.1EM,#FFF 2.1EM)",
      "expected": "background:LINEAR-GRADIENT(#FFF,#FFF 2EM,#CCC 0,#CCC 2.1EM,#FFF 0)"
    },
    {
      "test": "should not mangle floating point numbers 1 (uppercase)",
      "input": "background:lInEaR-gRaDiEnT(#fFf,#fFf 2Em,#cCc 2eM,#cCc 2.1eM,#fFf 2.1EM)",
      "expected": "background:lInEaR-gRaDiEnT(#fFf,#fFf 2Em,#cCc 0,#cCc 2.1eM,#fFf 0)"
    },
    {
      "test": "should not remove the trailing zero if it is the last stop",
      "input": "background: linear-gradient(90deg,transparent,#00aeef 0)",
      "expected": "background: linear-gradient(90deg,transparent,#00aeef 0)",
      "passthrough": true
    },
    {
      "test": "should not remove point number if it its different type from a previous one",
      "input": "background: linear-gradient(to left bottom,transparent calc(50% - 2px),#a7a7a8 0,#a7a7a8 calc(50% + 2px),transparent 0)",
      "expected": "background: linear-gradient(to left bottom,transparent calc(50% - 2px),#a7a7a8 0,#a7a7a8 calc(50% + 2px),transparent 0)",
      "passthrough": true
    },
    {
      "test": "should not throw on empty linear gradients",
      "input": "background: linear-gradient()",
      "expected": "background: linear-gradient()",
      "passthrough": true
    },
    {
      "test": "should not throw on empty radial gradients",
      "input": "background: radial-gradient()",
      "expected": "background: radial-gradient()",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references",
      "input": "background-image:var(--bg),linear-gradient(red,blue)",
      "expected": "background-image:var(--bg),linear-gradient(red,blue)",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #2",
      "input": "background:linear-gradient(to var(--var), transparent, black) 0% 50% no-repeat",
      "expected": "background:linear-gradient(to var(--var), transparent, black) 0% 50% no-repeat",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #3",
      "input": "background:linear-gradient(var(--var), transparent, black) 0% 50% no-repeat",
      "expected": "background:linear-gradient(var(--var), transparent, black) 0% 50% no-repeat",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #4",
      "input": "background:linear-gradient(var(--var), black) 0% 50% no-repeat",
      "expected": "background:linear-gradient(var(--var), black) 0% 50% no-repeat",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #5",
      "input": "background:linear-gradient(var(--var)) 0% 50% no-repeat",
      "expected": "background:linear-gradient(var(--var)) 0% 50% no-repeat",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #6",
      "input": "background:linear-gradient(var(--var), rgba(255,0,0,0) 70.71%)",
      "expected": "background:linear-gradient(var(--var), rgba(255,0,0,0) 70.71%)",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #7",
      "input": "background:linear-gradient(to env(--var), transparent, black) 0% 50% no-repeat",
      "expected": "background:linear-gradient(to env(--var), transparent, black) 0% 50% no-repeat",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #8",
      "input": "background:linear-gradient(var(--var))",
      "expected": "background:linear-gradient(var(--var))",
      "passthrough": true
    },
    {
      "test": "should pass through custom property references #9",
      "input": "background:linear-gradient(var(--foo), var(--bar), var(--baz))",
      "expected": "background:linear-gradient(var(--foo), var(--bar), var(--baz))",
      "passthrough": true
    },
    {
      "test": "should pass through env property references",
      "input": "background:linear-gradient(env(--var))",
      "expected": "background:linear-gradient(env(--var))",
      "passthrough": true
    },
    {
      "test": "should not throw error on broken syntax",
      "input": "background:",
      "expected": "background:",
      "passthrough": true
    },
    {
      "test": "should not operate on declarations without gradients",
      "input": "background:red",
      "expected": "background:red",
      "passthrough": true
    },
    {
      "test": "should pass through oklch color stops in gradients",
      "input": "background:linear-gradient(oklch(0.5 0.2 240),oklch(0.8 0.1 200))",
      "expected": "background:linear-gradient(oklch(0.5 0.2 240),oklch(0.8 0.1 200))",
      "passthrough": true
    },
    {
      "test": "should pass through oklab color stops in gradients",
      "input": "background:linear-gradient(oklab(0.5 0.1 -0.2),oklab(0.8 0.05 -0.1))",
      "expected": "background:linear-gradient(oklab(0.5 0.1 -0.2),oklab(0.8 0.05 -0.1))",
      "passthrough": true
    },
    {
      "test": "should pass through hwb color stops in gradients",
      "input": "background:linear-gradient(hwb(0 0% 0%),hwb(240 0% 0%))",
      "expected": "background:linear-gradient(hwb(0 0% 0%),hwb(240 0% 0%))",
      "passthrough": true
    },
    {
      "test": "should pass through lch color stops in gradients",
      "input": "background:linear-gradient(lch(50 100 30),lch(80 50 200))",
      "expected": "background:linear-gradient(lch(50 100 30),lch(80 50 200))",
      "passthrough": true
    }
  ]
}
