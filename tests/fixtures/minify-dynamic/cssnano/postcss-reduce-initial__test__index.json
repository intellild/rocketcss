{
  "upstream": "packages/postcss-reduce-initial/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "cursor: initial => cursor: auto (uppercase property and value)",
      "input": "CURSOR: INITIAL",
      "expected": "CURSOR: auto"
    },
    {
      "test": "z-index: initial => z-index: auto (uppercase property and value)",
      "input": "Z-INDEX: INITIAL",
      "expected": "Z-INDEX: auto"
    },
    {
      "test": "border-block-color: currentColor => border-block-color: initial",
      "input": "border-block-color: currentColor",
      "expected": "border-block-color: initial"
    },
    {
      "test": "BORDER-BLOCK-COLOR: CURRENTCOLOR => border-block-color: initial (uppercase property and value)",
      "input": "BORDER-BLOCK-COLOR: CURRENTCOLOR",
      "expected": "BORDER-BLOCK-COLOR: initial"
    },
    {
      "test": "should pass through when an initial value is longer",
      "input": "writing-mode:initial",
      "expected": "writing-mode:initial",
      "passthrough": true
    },
    {
      "test": "should pass through when an initial value is longer (uppercase property and value)",
      "input": "WRITING-MODE:INITIAL",
      "expected": "WRITING-MODE:INITIAL",
      "passthrough": true
    },
    {
      "test": "should pass through non-initial values",
      "input": "all:inherit",
      "expected": "all:inherit",
      "passthrough": true
    },
    {
      "test": "should pass through non-initial values (uppercase property and value)",
      "input": "ALL:INHERIT",
      "expected": "ALL:INHERIT",
      "passthrough": true
    },
    {
      "test": "min-width auto tests",
      "input": "h1{min-width:initial}",
      "expected": "h1{min-width:auto}"
    },
    {
      "test": "min-height auto tests",
      "input": "h1{min-height:initial}",
      "expected": "h1{min-height:auto}"
    },
    {
      "test": "preserve no-repeat mask-repeat",
      "input": "div{mask-repeat:no-repeat}",
      "expected": "div{mask-repeat:no-repeat}",
      "passthrough": true
    },
    {
      "test": "transform initial mask-repeat to repeat",
      "input": "div{mask-repeat:initial}",
      "expected": "div{mask-repeat:repeat}"
    },
    {
      "test": "preserve transform-box",
      "input": "div{transform-box:view-box}",
      "expected": "div{transform-box:view-box}",
      "passthrough": true
    },
    {
      "test": "should preserve initial -webkit-line-clamp",
      "input": "a{-webkit-line-clamp: initial;}",
      "expected": "a{-webkit-line-clamp: initial;}",
      "passthrough": true
    },
    {
      "test": "should ignore the data present in the ignore options",
      "input": "h1{min-height:initial}",
      "expected": "h1{min-height:initial}",
      "passthrough": true
    },
    {
      "test": "should ignore the data present in the ignore options #2",
      "input": "h1{  writing-mode: sideways-rl;}",
      "expected": "h1{  writing-mode: sideways-rl;}"
    },
    {
      "test": "should ignore the data present in the ignore options #3",
      "input": "h1{  writing-mode: vertical-lr;}",
      "expected": "h1{  writing-mode: vertical-lr;}"
    },
    {
      "test": "should ignore the data present in the ignore options , toInitial #3",
      "input": "WRITING-MODE:horizontal-tb",
      "expected": "WRITING-MODE:horizontal-tb",
      "passthrough": true
    }
  ]
}
