      "expected": "h1 /*!test comment*/,h2{color:blue}"
    },
    {
      "test": "should not be responsible for normalising coments (2)",
      "input": "/*!test   comment*/h1, h2{color:blue}",
      "expected": "/*!test   comment*/h1,h2{color:blue}"
    },
    {
      "test": "should transform ::before to :before",
      "input": "h1::before{color:blue}",
      "expected": "h1:before{color:blue}"
    },
    {
      "test": "should transform ::before to :before (2)",
      "input": "h1::BEFORE{color:blue}",
      "expected": "h1:BEFORE{color:blue}"
    },
    {
      "test": "should transform ::after to :after",
      "input": "h1::after{color:blue}",
      "expected": "h1:after{color:blue}"
    },
    {
      "test": "should transform ::first-letter to :first-letter",
      "input": "h1::first-letter{color:blue}",
      "expected": "h1:first-letter{color:blue}"
    },
    {
      "test": "should transform ::first-line to :first-line",
      "input": "h1::first-line{color:blue}",
      "expected": "h1:first-line{color:blue}"
    },
    {
      "test": "should not change strings",
      "input": ":not([attr=\"  h1       a + b /* not a comment */ end of :not  from 100% \"]){color:blue}",
      "expected": ":not([attr=\"  h1       a + b /* not a comment */ end of :not  from 100% \"]){color:blue}",
      "passthrough": true
    },
    {
      "test": "should not change strings (2)",
      "input": ":not([attr=\"  h1       a + b /* not a comment */ not end of `:not`:  )  from 100% \"]){color:blue}",
      "expected": ":not([attr=\"  h1       a + b /* not a comment */ not end of `:not`:  )  from 100% \"]){color:blue}",
      "passthrough": true
    },
    {
      "test": "should not change strings (3)",
      "input": "[a=\":not( *.b, h1, h1 )\"]{color:blue}",
      "expected": "[a=\":not( *.b, h1, h1 )\"]{color:blue}",
      "passthrough": true
    },
    {
      "test": "should not change strings (4)",
