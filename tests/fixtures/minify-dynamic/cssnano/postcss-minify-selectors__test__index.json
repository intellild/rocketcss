{
  "upstream": "packages/postcss-minify-selectors/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should trim spaces in simple selectors",
      "input": "h1,  h2,  h3{color:blue}",
      "expected": "h1,h2,h3{color:blue}"
    },
    {
      "test": "should trim spaces around combinators",
      "input": "h1 + p, h1 > p, h1 ~ p{color:blue}",
      "expected": "h1+p,h1>p,h1~p{color:blue}"
    },
    {
      "test": "should not trim meaningful spaces",
      "input": "H2 p,h1 p{color:blue}",
      "expected": "H2 p,h1 p{color:blue}",
      "passthrough": true
    },
    {
      "test": "should reduce meaningful spaces",
      "input": "h1    p,h2     p{color:blue}",
      "expected": "h1 p,h2 p{color:blue}"
    },
    {
      "test": "should remove qualified universal selectors",
      "input": "*#id,*.test,*:not(.green),*[href]{color:blue}",
      "expected": "#id,.test,:not(.green),[href]{color:blue}"
    },
    {
      "test": "should remove complex qualified universal selectors",
      "input": "[class] + *[href] *:not(*.green){color:blue}",
      "expected": "[class]+[href] :not(.green){color:blue}"
    },
    {
      "test": "should remove complex qualified universal selectors (2)",
      "input": "*:not(*.green) ~ *{color:blue}",
      "expected": ":not(.green)~*{color:blue}"
    },
    {
      "test": "should not remove meaningful universal selectors",
      "input": "* + *, * > *, * h1, * ~ *{color:blue}",
      "expected": "* h1,*+*,*>*,*~*{color:blue}"
    },
    {
      "test": "should preserve the universal selector between comments",
      "input": "/*comment*/*/*comment*/{color:blue}",
      "expected": "/*comment*/*/*comment*/{color:blue}",
      "passthrough": true
    },
    {
      "test": "should preserve the universal selector in attribute selectors",
      "input": "h1[class=\" *.js \"] + *.js{color:blue}",
      "expected": "h1[class=\" *.js \"]+.js{color:blue}"
    },
    {
      "test": "should preserve the universal selector in filenames",
      "input": "[filename=\"*.js\"]{color:blue}",
      "expected": "[filename=\"*.js\"]{color:blue}",
      "passthrough": true
    },
    {
      "test": "should preserve the universal selector in file globs",
      "input": "[glob=\"/**/*.js\"]{color:blue}",
      "expected": "[glob=\"/**/*.js\"]{color:blue}",
      "passthrough": true
    },
    {
      "test": "should preserve escaped zero plus sequences",
      "input": ".\\31 0\\+,.\\31 5\\+,.\\32 0\\+{color:blue}",
      "expected": ".\\31 0\\+,.\\31 5\\+,.\\32 0\\+{color:blue}",
      "passthrough": true
    },
    {
      "test": "should handle deep combinators",
      "input": "body /deep/ .theme-element{color:blue}",
      "expected": "body/deep/.theme-element{color:blue}"
    },
    {
      "test": "should sort",
      "input": ".item1, .item2, .item10, .item11{color:blue}",
      "expected": ".item1,.item10,.item11,.item2{color:blue}"
    },
    {
      "test": "should not sort",
      "input": ".item1, .item2, .item10, .item11{color:blue}",
      "expected": ".item1,.item2,.item10,.item11{color:blue}"
    },
    {
      "test": "should dedupe selectors",
      "input": "h1,h2,h3,h4,h5,h5,h6{color:blue}",
      "expected": "h1,h2,h3,h4,h5,h6{color:blue}"
    },
    {
      "test": "should trim spaces in :not()",
      "input": "h1:not(.article, .comments){color:blue}",
      "expected": "h1:not(.article,.comments){color:blue}"
    },
    {
      "test": "should trim spaces in :not() (2)",
      "input": "h1:not(.article, .comments), h2:not(.lead, .recommendation){color:blue}",
      "expected": "h1:not(.article,.comments),h2:not(.lead,.recommendation){color:blue}"
    },
    {
      "test": "should dedupe simple selectors inside :not()",
      "input": "h1:not(h2, h3, h4, h5, h5, h6){color:blue}",
      "expected": "h1:not(h2,h3,h4,h5,h6){color:blue}"
    },
    {
      "test": "should normalise attribute selectors",
      "input": "a[   color=   \"blue\"    ]{color:blue}",
      "expected": "a[color=blue]{color:blue}"
    },
    {
      "test": "should normalise attribute selectors (2)",
      "input": "a[class^=\"options[\"]:after{color:blue}",
      "expected": "a[class^=\"options[\"]:after{color:blue}",
      "passthrough": true
    },
    {
      "test": "should normalise attribute selectors (3)",
      "input": "a[class=\"woop_woop_woop\"]{color:blue}",
      "expected": "a[class=woop_woop_woop]{color:blue}"
    },
    {
      "test": "should normalise attribute selectors (4)",
      "input": "a[class=\"woop \\\nwoop woop\"]{color:blue}",
      "expected": "a[class=\"woop woop woop\"]{color:blue}"
    },
    {
      "test": "should normalise attribute selectors (5)",
      "input": "a[   color   =   \"blue\"    ]{color:blue}",
      "expected": "a[color=blue]{color:blue}"
    },
    {
      "test": "should normalise attribute selectors (6)",
      "input": "a[color=\"blue\"   i   ]{color:blue}",
      "expected": "a[color=blue i]{color:blue}"
    },
    {
      "test": "should normalise attribute selectors (7)",
      "input": "a[   target   ]{color:blue}",
      "expected": "a[target]{color:blue}"
    },
    {
