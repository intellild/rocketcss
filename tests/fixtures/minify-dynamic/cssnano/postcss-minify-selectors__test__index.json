    },
    {
      "test": "fold: MDN level-1 section headings example",
      "input": "section h1, article h1, aside h1, nav h1{font-size:25px}",
      "expected": ":is(article,aside,nav,section) h1{font-size:25px}"
    },
    {
      "test": "fold: common suffix with multiple selectors",
      "input": "section h1,article h1,aside h1,nav h1{font-size:25px}",
      "expected": ":is(article,aside,nav,section) h1{font-size:25px}"
    },
    {
      "test": "fold: common prefix with multiple selectors",
      "input": ".foo .a .x,.foo .b .x,.foo .c .x{color:red}",
      "expected": ".foo :is(.a,.b,.c) .x{color:red}"
    },
    {
      "test": "fold: common prefix and suffix",
      "input": ".nav .item .home,.nav .item .shop,.nav .item .help{color:red}",
      "expected": ".nav .item :is(.help,.home,.shop){color:red}"
    },
    {
      "test": "no-fold: combinator in middle (MDN deep list-style example, 16-way)",
      "input": "ol ol ul,ol ul ul,ol menu ul,ol dir ul,ul ol ul,ul ul ul,ul menu ul,ul dir ul,menu ol ul,menu ul ul,menu menu ul,menu dir ul,dir ol ul,dir ul ul,dir menu ul,dir dir ul{list-style:square}",
      "expected": "dir dir ul,dir menu ul,dir ol ul,dir ul ul,menu dir ul,menu menu ul,menu ol ul,menu ul ul,ol dir ul,ol menu ul,ol ol ul,ol ul ul,ul dir ul,ul menu ul,ul ol ul,ul ul ul{list-style:square}"
    },
    {
      "test": "fold: pseudo-class in middle (same specificity)",
      "input": ".btn a:hover,.btn a:focus,.btn a:active{color:red}",
      "expected": ".btn :is(a:active,a:focus,a:hover){color:red}"
    },
    {
      "test": "no-fold: functional pseudo in middle (outside allowlist)",
      "input": ".box :not(.a) .x,.box :not(.b) .x,.box :not(.c) .x{color:red}",
      "expected": ".box :not(.a) .x,.box :not(.b) .x,.box :not(.c) .x{color:red}"
    },
    {
      "test": "fold: universal selector in common part stays outside `:is()`",
      "input": ".a * .x,.b * .x,.c * .x{color:red}",
      "expected": ":is(.a,.b,.c) * .x{color:red}"
    },
    {
      "test": "fold: child combinator in common prefix",
      "input": ".wrap > .a .x,.wrap > .b .x,.wrap > .c .x{color:red}",
      "expected": ".wrap>:is(.a,.b,.c) .x{color:red}"
    },
    {
      "test": "fold: sibling combinator in common prefix",
      "input": ".a~.m,.a~.n,.a~.o{color:red}",
      "expected": ".a~:is(.m,.n,.o){color:red}"
    },
    {
      "test": "fold: adjacent-sibling combinator in common prefix",
      "input": ".a+.m,.a+.n,.a+.o{color:red}",
      "expected": ".a+:is(.m,.n,.o){color:red}"
    },
    {
      "test": "fold: compound selector (multi-class) in common prefix",
      "input": ".menu.open a,.menu.open b,.menu.open c{color:red}",
      "expected": ".menu.open :is(a,b,c){color:red}"
    },
    {
      "test": "fold: multi-simple compound middle with same specificity",
      "input": ".root a.x b,.root a.y b,.root a.z b{color:red}",
      "expected": ".root :is(a.x,a.y,a.z) b{color:red}"
    },
    {
      "test": "fold: ids in middle (all same specificity)",
      "input": "#a .x,#b .x,#c .x{color:red}",
      "expected": ":is(#a,#b,#c) .x{color:red}"
    },
    {
      "test": "fold: attribute selectors with matching specificity",
      "input": "[data-a] .item .x,[data-b] .item .x,[data-c] .item .x{color:red}",
      "expected": ":is([data-a],[data-b],[data-c]) .item .x{color:red}"
    },
    {
      "test": "fold: pseudo-class after compound in common prefix",
      "input": ".tab:hover .a,.tab:hover .b,.tab:hover .c{color:red}",
      "expected": ".tab:hover :is(.a,.b,.c){color:red}"
    },
    {
      "test": "fold: does not touch nested `&` selectors",
      "input": "& .a .x,& .b .x,& .c .x{color:red}",
      "expected": "& :is(.a,.b,.c) .x{color:red}"
    },
    {
      "test": "fold: dedupes identical middles",
      "input": ".foo .a .x,.foo .a .x,.foo .b .x{color:red}",
      "expected": ".foo :is(.a,.b) .x{color:red}"
    },
    {
      "test": "fold: survives duplicates being removed before fold",
      "input": ".a .x,.a .x,.a .y,.a .z{color:red}",
      "expected": ".a :is(.x,.y,.z){color:red}"
    },
    {
      "test": "no-fold: 2-selector pair without byte savings is left alone",
      "input": "ol li a, ul li a{color:red}",
      "expected": "ol li a,ul li a{color:red}"
    },
    {
      "test": "no-fold: byte-neutral 2-selector child-combinator case",
      "input": ".foo>.a,.foo>.b{color:red}",
      "expected": ".foo>.a,.foo>.b{color:red}"
    },
    {
      "test": "no-fold: only fires when strictly shorter",
      "input": "a c,b c{color:red}",
      "expected": "a c,b c{color:red}"
    },
    {
      "test": "no-fold: rejects mixed-specificity middles (id vs class)",
      "input": ".a b,#x b,.c b{color:red}",
      "expected": "#x b,.a b,.c b{color:red}"
    },
    {
      "test": "no-fold: rejects mixed-specificity middles (tag vs class)",
      "input": "ol li a,ul li a,.menu li a{color:red}",
      "expected": ".menu li a,ol li a,ul li a{color:red}"
    },
    {
      "test": "no-fold: rejects universal vs tag in middle (different specificity)",
      "input": "* h1,body h1{font-size:1rem}",
      "expected": "* h1,body h1{font-size:1rem}"
    },
    {
      "test": "no-fold: rejects :not() with differing inner specificity",
      "input": ".p :not(.a) b,.p :not(#x) b{color:red}",
      "expected": ".p :not(#x) b,.p :not(.a) b{color:red}"
    },
    {
      "test": "no-fold: rejects pseudo-element in middle",
      "input": ".a::before,.b::before,.c::before{content:\"\"}",
      "expected": ".a:before,.b:before,.c:before{content:\"\"}"
    },
    {
      "test": "no-fold: rejects legacy single-colon pseudo-element in middle",
      "input": ".a:before,.b:before,.c:before{content:\"\"}",
      "expected": ".a:before,.b:before,.c:before{content:\"\"}"
    },
    {
      "test": "no-fold: rejects pseudo-element that survived `::` → `:` shortening",
      "input": ".t a:hover::after,.t b:hover::after,.t c:hover::after{content:\"x\"}",
      "expected": ".t a:hover:after,.t b:hover:after,.t c:hover:after{content:\"x\"}"
    },
    {
      "test": "no-fold: pseudo-element in common part stays put (not pulled into `:is()`)",
      "input": "a::before h1,b::before h1,c::before h1{content:\"x\"}",
      "expected": "a:before h1,b:before h1,c:before h1{content:\"x\"}"
    },
    {
      "test": "no-fold: keyframes percentages are untouched (no combinator context)",
      "input": "@keyframes k{0%,50%,to{opacity:0}}",
      "expected": "@keyframes k{0%,50%,to{opacity:0}}"
    },
    {
      "test": "no-fold: rejects combinator in middle when prefix is non-empty (child)",
      "input": ".card>.header>.title,.card>.footer>.meta{color:red}",
      "expected": ".card>.footer>.meta,.card>.header>.title{color:red}"
    },
    {
      "test": "no-fold: rejects combinator in middle when prefix is non-empty (descendant)",
      "input": ".x .a .b,.x .c .d{color:red}",
      "expected": ".x .a .b,.x .c .d{color:red}"
    },
    {
      "test": "no-fold: already-nested `:is()` when result would not be shorter",
      "input": ":is(.a,.b) .x,:is(.c,.d) .x{color:red}",
      "expected": ":is(.a,.b) .x,:is(.c,.d) .x{color:red}"
    },
    {
      "test": "no-fold: idempotent on already-folded output",
      "input": ":is(article,aside,nav,section) h1{font-size:25px}",
      "expected": ":is(article,aside,nav,section) h1{font-size:25px}"
    },
    {
      "test": "no-fold: single-selector rules",
      "input": ".foo .bar{color:red}",
      "expected": ".foo .bar{color:red}"
    },
    {
      "test": "no-fold: mixin-like selectors",
      "input": ".mixin:{color:red}",
      "expected": ".mixin:{color:red}"
    },
    {
      "test": "fold: disabled by convertToIs=false",
      "input": "section h1,article h1,aside h1,nav h1{font-size:25px}",
      "expected": "article h1,aside h1,nav h1,section h1{font-size:25px}"
    },
    {
      "test": "fold: disabled when browserslist does not support :is() (IE 11)",
      "input": "section h1,article h1,aside h1,nav h1{font-size:25px}",
      "expected": "article h1,aside h1,nav h1,section h1{font-size:25px}"
    },
    {
      "test": "fold: disabled when any target in a list is unsupported",
      "input": "section h1,article h1,aside h1,nav h1{font-size:25px}",
      "expected": "article h1,aside h1,nav h1,section h1{font-size:25px}"
    },
    {
      "test": "fold: honours sort=false (does not re-sort middles after fold)",
      "input": ".foo .z .x,.foo .a .x,.foo .m .x{color:red}",
      "expected": ".foo :is(.z,.a,.m) .x{color:red}"
    },
    {
      "test": "fold: sort=true reorders middles alphabetically",
      "input": ".foo .z .x,.foo .a .x,.foo .m .x{color:red}",
      "expected": ".foo :is(.a,.m,.z) .x{color:red}"
    }
  ]
}
