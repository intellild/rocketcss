      "expected": "[a=\"escaped quotes \\\" h1, h1, h1 \\\" h1, h1, h1\"]{color:blue}",
      "passthrough": true
    },
    {
      "test": "should not change strings (5)",
      "input": "[a='escaped quotes \\' h1, h1, h1 \\' h1, h1, h1']{color:blue}",
      "expected": "[a='escaped quotes \\' h1, h1, h1 \\' h1, h1, h1']{color:blue}",
      "passthrough": true
