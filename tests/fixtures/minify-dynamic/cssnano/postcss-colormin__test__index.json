{
  "upstream": "packages/postcss-colormin/test/index.js",
  "revision": "26c943569ea56fd71932f35a039860e6e53e06e9",
  "cases": [
    {
      "test": "should minify lowercase color values",
      "input": "h1{color:yellow}",
      "expected": "h1{color:#ff0}"
    },
    {
      "test": "should minify uppercase color values",
      "input": "h1{COLOR:YELLOW}",
      "expected": "h1{COLOR:#ff0}"
    },
    {
      "test": "should minify color values (2)",
      "input": "h1{box-shadow:0 1px 3px rgba(255, 230, 220, 0.5)}",
      "expected": "h1{box-shadow:0 1px 3px rgba(255,230,220,.5)}"
    },
    {
      "test": "should minify color values (3)",
      "input": "h1{background:hsla(134, 50%, 50%, 1)}",
      "expected": "h1{background:#40bf5e}"
    },
    {
      "test": "should minify color values (4)",
      "input": "h1{text-shadow:1px 1px 2px #000000}",
      "expected": "h1{text-shadow:1px 1px 2px #000}"
    },
    {
      "test": "should minify color values (5)",
      "input": "h1{text-shadow:1px 1px 2px rgb(255, 255, 255)}",
      "expected": "h1{text-shadow:1px 1px 2px #fff}"
    },
    {
      "test": "should minify color values (6)",
      "input": "h1{text-shadow:1px 1px 2px hsl(0,0%,100%)}",
      "expected": "h1{text-shadow:1px 1px 2px #fff}"
    },
    {
      "test": "should minify color values (7)",
      "input": "h1{background:HSLA(134, 50%, 50%, 1)}",
      "expected": "h1{background:#40bf5e}"
    },
    {
      "test": "should minify color values (8)",
      "input": "h1{background:#FFFFFF}",
      "expected": "h1{background:#fff}"
    },
    {
      "test": "should minify color values (9)",
      "input": "h1{background:#F0FFFF}",
      "expected": "h1{background:azure}"
    },
    {
      "test": "should minify color values (11)",
      "input": "h1{background:#F0FFFF;background:#F0FFFF}",
      "expected": "h1{background:azure;background:azure}"
    },
    {
      "test": "should minify color values in background gradients",
      "input": "h1{background:linear-gradient( #ff0000,yellow )}",
      "expected": "h1{background:linear-gradient( red,#ff0 )}"
    },
    {
      "test": "should minify color values in background gradients (2)",
      "input": "h1{background:linear-gradient(yellow, orange), linear-gradient(black, rgba(255, 255, 255, 0))}",
      "expected": "h1{background:linear-gradient(#ff0, orange), linear-gradient(#000, hsla(0,0%,100%,0))}"
    },
    {
      "test": "should minify color values in background gradients (3)",
      "input": "h1{background:linear-gradient(0deg, yellow, black 40%, red)}",
      "expected": "h1{background:linear-gradient(0deg, #ff0, #000 40%, red)}"
    },
    {
      "test": "should not minify in font properties",
      "input": "h1{font-family:black}",
      "expected": "h1{font-family:black}",
      "passthrough": true
    },
    {
      "test": "should make an exception for webkit tap highlight color (issue 1)",
      "input": "h1{-webkit-tap-highlight-color:rgba(0,0,0,0)}",
      "expected": "h1{-webkit-tap-highlight-color:rgba(0,0,0,0)}",
      "passthrough": true
    },
    {
      "test": "should not crash on transparent in webkit tap highlight color",
      "input": "h1{-webkit-tap-highlight-color:transparent}",
      "expected": "h1{-webkit-tap-highlight-color:transparent}",
      "passthrough": true
    },
    {
      "test": "should not crash on inherit in webkit tap highlight color",
      "input": "h1{-webkit-tap-highlight-color:inherit}",
      "expected": "h1{-webkit-tap-highlight-color:inherit}",
      "passthrough": true
    },
    {
      "test": "should minify color stops",
      "input": "h1{background-image:-webkit-gradient(linear,50% 0%,50% 100%,color-stop(1px, #fbfbfb),color-stop(1px, #ffffff),color-stop(2px, #ffffff),color-stop(2px, #fbfbfb),color-stop(100%, #ececec))}",
      "expected": "h1{background-image:-webkit-gradient(linear,50% 0%,50% 100%,color-stop(1px, #fbfbfb),color-stop(1px, #fff),color-stop(2px, #fff),color-stop(2px, #fbfbfb),color-stop(100%, #ececec))}"
    },
    {
      "test": "should not minify in lowercase calc values",
      "input": "h1{width:calc(100vw / 2 - 6px + 0)}",
      "expected": "h1{width:calc(100vw / 2 - 6px + 0)}",
      "passthrough": true
    },
    {
      "test": "should not minify in uppercase calc values",
      "input": "h1{width:CALC(100vw / 2 - 6px + 0)}",
      "expected": "h1{width:CALC(100vw / 2 - 6px + 0)}",
      "passthrough": true
    },
    {
      "test": "should minify hex colors without keywords",
      "input": "h1{background:linear-gradient(#ffffff,#999999) no-repeat;}",
      "expected": "h1{background:linear-gradient(#fff,#999) no-repeat;}"
    },
    {
      "test": "should not mangle percentage based rgba values",
      "input": "h1{color:rgba(50%, 50%, 50%, 0.5)}",
      "expected": "h1{color:hsla(0,0%,50%,.5)}"
    },
    {
      "test": "should convert percentage based rgba values",
      "input": "h1{color:rgb(100%,100%,100%)}",
      "expected": "h1{color:#fff}"
    },
    {
      "test": "should handle errored cases",
      "input": "h1{color:rgb(50%, 23, 54)}",
      "expected": "h1{color:rgb(50%, 23, 54)}",
      "passthrough": true
    },
    {
      "test": "should add extra spaces when converting rgb",
      "input": "h1{background:linear-gradient(rgb(50, 50, 50)0%,blue 100%)}",
      "expected": "h1{background:linear-gradient(#323232 0%,blue 100%)}"
    },
    {
      "test": "should add extra spaces when converting rgb (2)",
      "input": "h1{background:linear-gradient(rgba(0,0,0,0)0%, blue 100%)}",
      "expected": "h1{background:linear-gradient(transparent 0%, blue 100%)}"
    },
    {
      "test": "should add extra spaces when converting rgb (3)",
      "input": "h1{background:rgb(1,2,3)url(bar.png)}",
      "expected": "h1{background:#010203 url(bar.png)}"
    },
    {
      "test": "should save extra spaces when converting hex",
      "input": "h1{background:#F0FFFF url(bar.png)}",
      "expected": "h1{background:azure url(bar.png)}"
    },
    {
      "test": "should passthrough css variables named as a color",
      "input": "h1{color:var(--white)}",
      "expected": "h1{color:var(--white)}",
      "passthrough": true
    },
    {
      "test": "should passthrough broken syntax",
      "input": "h1{color:}",
      "expected": "h1{color:}",
      "passthrough": true
    },
    {
      "test": "should not convert this specific rgba value to \"transparent\" (old IE)",
      "input": "h1{color:rgba(0,0,0,0)}",
      "expected": "h1{color:rgba(0,0,0,0)}",
      "passthrough": true
    },
    {
      "test": "should not mangle colours in the content property",
      "input": "h2:before{content:\"black\"}",
      "expected": "h2:before{content:\"black\"}",
      "passthrough": true
    },
    {
      "test": "should not attempt to convert z-index",
      "input": "h1{z-index:999}",
      "expected": "h1{z-index:999}",
      "passthrough": true
    },
    {
      "test": "should not attempt to convert variables",
      "input": ":root{--some-color: 200 255 0}",
      "expected": ":root{--some-color: 200 255 0}",
      "passthrough": true
    },
    {
      "test": "should minify colors inside custom properties by default",
      "input": "a{--foo:rgb(0 0 0)}",
      "expected": "a{--foo:#000}"
    },
    {
      "test": "should not minify colors inside custom properties when transformCustomProperties is false",
      "input": "a{--foo:rgb(0 0 0)}",
      "expected": "a{--foo:rgb(0 0 0)}",
      "passthrough": true
    },
    {
      "test": "should respect CSS variables",
      "input": "div{background-color:rgba(51,153,255,var(--tw-bg-opacity))}",
      "expected": "div{background-color:rgba(51,153,255,var(--tw-bg-opacity))}",
      "passthrough": true
    },
    {
      "test": "should convert long color to 8-digit hex when supported",
      "input": "h1{color:rgba(100% 50% 0% / 50%)}",
      "expected": "h1{color:#ff800080}"
    },
    {
      "test": "should convert long color to 4-digit hex when supported",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:#f006}"
    },
    {
      "test": "should convert long color based on Browserslist config [legacy] env",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:rgba(255,0,0,.4)}"
    },
    {
      "test": "should convert long color based on Browserslist config [legacy] env using webpack file path",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:rgba(255,0,0,.4)}"
    },
    {
      "test": "should convert long color based on Browserslist config [legacy] env using custom path",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:rgba(255,0,0,.4)}"
    },
    {
      "test": "should convert long color based on Browserslist config [modern] env",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:#f006}"
    },
    {
      "test": "should convert long color based on Browserslist config [modern] env using webpack file path",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:#f006}"
    },
    {
      "test": "should convert long color based on Browserslist config [modern] env using custom path",
      "input": "h1{color:hsla(0 100% 50% / 40%)}",
      "expected": "h1{color:#f006}"
    },
    {
      "test": "should not attempt to convert font names",
      "input": "@font-face{src:local(Noto Sans Black)}",
      "expected": "@font-face{src:local(Noto Sans Black)}",
      "passthrough": true
    },
    {
      "test": "should minify space-separated rgb() to shortest form",
      "input": "h1{color:rgb(255 0 0)}",
      "expected": "h1{color:red}"
    },
    {
      "test": "should minify space-separated rgb() with slash alpha",
      "input": "h1{color:rgb(255 0 0 / 0.5)}",
      "expected": "h1{color:rgba(255,0,0,.5)}"
    },
    {
      "test": "should minify space-separated hsl() to shortest form",
      "input": "h1{color:hsl(0 100% 50%)}",
      "expected": "h1{color:red}"
    },
    {
      "test": "should pass through oklch() values unchanged",
      "input": "h1{color:oklch(0.6279 0.2577 29.23)}",
      "expected": "h1{color:oklch(0.6279 0.2577 29.23)}",
      "passthrough": true
    },
    {
      "test": "should pass through oklab() values unchanged",
      "input": "h1{color:oklab(0.5 0.1 -0.2)}",
      "expected": "h1{color:oklab(0.5 0.1 -0.2)}",
      "passthrough": true
    },
    {
      "test": "should pass through hwb() values unchanged",
      "input": "h1{color:hwb(120 0% 0%)}",
      "expected": "h1{color:hwb(120 0% 0%)}",
      "passthrough": true
    }
  ]
}
